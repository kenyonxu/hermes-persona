{
  "hermes-persona": {
    "modules": {
      "time": true,
      "static_rules": true,
      "dynamic": {
        "time_slots": true,
        "turn_stage": true,
        "keyword": true
      },
      "variance": true,
      "memory": false,
      "kanban": true,
      "debug": false
    },
    "time": {
      "enabled": true,
      "format": "cn_full"
    },
    "context": {
      "rules": [
        "你是一个友好的AI助手",
        "请用简洁清晰的语言回答"
      ],
      "rules_first_turn_only": [
        "这是本次会话的第一条消息，请向用户打招呼"
      ]
    },
    "dynamic": {
      "time_slots": {
        "22:00-05:00": [
          "现在是深夜时段，回复可以更加温柔安静",
          "深夜了，别忘了提醒用户早点休息"
        ],
        "09:00-17:00": [
          "现在是工作时间，回复应保持专业高效"
        ]
      },
      "turn_stage": {
        "first_turn": [
          "首次交流，建立友好的对话氛围"
        ],
        "after_10": [
          "对话已进行一段时间，保持上下文连贯"
        ],
        "after_30": [
          "这是一个较长的对话，适时总结和确认"
        ]
      },
      "keywords": {}
    },
    "expression_vector": {
      "enabled": true,
      "dimensions": {
        "work": ["代码", "架构", "Bug", "PR", "测试", "重构", "commit", "push", "部署"],
        "future": ["愿景", "十年后", "梦想", "未来", "规划"],
        "intimacy": ["陪伴", "累了", "一起", "温暖"]
      },
      "score_rules": {
        "work": [1, -0.5, 1],
        "future": [1, -1, 1],
        "intimacy": [1, -0.5, 3]
      },
      "reset": "session",
      "storage_path": "~/.hermes/profiles/{profile}/state/expression_vector.json"
    },
    "fixed_signals": {
      "message_length": {
        "enabled": true,
        "threshold": 50
      },
      "reply_gap": {
        "enabled": true,
        "threshold_minutes": 30,
        "storage_path": "~/.hermes/profiles/{profile}/state/reply_timing.json"
      }
    },
    "variance": {},
    "memory": {
      "enabled": false,
      "api_url": "",
      "max_results": 3
    },
    "project": {
      "enabled": false,
      "kanban_path": "",
      "label": ""
    },
    "guard": {
      "enabled": false,
      "rules": {
        "blocked": [
          {"pattern": "rm\\s", "reason": "文件删除操作已阻止"},
          {"pattern": "DROP\\s", "reason": "数据库删除操作已阻止"}
        ],
        "require_confirmation": [
          {"pattern": "git\\s+push", "reason": "代码推送需确认"}
        ]
      },
      "audit": {
        "enabled": false,
        "log_path": "~/.hermes/logs/persona-audit.log"
      }
    }
  }
}
